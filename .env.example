# Path to the SQLite database file (relative to project root)
# Copy this file to .env.local and adjust if needed
DATABASE_URL=./anime-quotes.db

# YouTube Data API v3 key
# Get one free at: https://console.cloud.google.com
# Enable "YouTube Data API v3", then create an API key under Credentials.
# Free quota: 10,000 units/day (each search = 100 units → 100 searches/day)
YOUTUBE_API_KEY=your_youtube_api_key_here
 nbu